{
  "name": "director-studio",
  "version": "1.0.0",
  "description": "电影导演工作室 — AI驱动的影视创作桌面App",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5174",
    "build": "vite build",
    "proxy": "node backend/server.cjs",
    "start": "concurrently \"node backend/server.cjs\" \"vite --host 0.0.0.0 --port 5174\"",
    "electron:dev": "concurrently \"vite --host 0.0.0.0 --port 5174 --https\" \"wait-on https://localhost:5174 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.director.studio",
    "productName": "导演工作室",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": null
  },
  "dependencies": {
    "@xyflow/react": "^12.11.0",
    "docx": "^8.5.0",
    "gsap": "^3.15.0",
    "mammoth": "^1.6.0",
    "pdfjs-dist": "^5.7.284",
    "pptxgenjs": "^3.12.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.0",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}
