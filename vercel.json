{
  "rewrites": [
    { "source": "/director-studio.mobileconfig", "destination": "/director-studio.mobileconfig" },
    { "source": "/install", "destination": "/install.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/director-studio.mobileconfig",
      "headers": [
        { "key": "Content-Type", "value": "application/x-apple-aspen-config" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [{ "key": "Content-Type", "value": "application/manifest+json" }]
    }
  ]
}
